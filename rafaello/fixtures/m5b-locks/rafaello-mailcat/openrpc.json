{
  "openrpc": "1.2.6",
  "info": { "title": "mailcat", "version": "0.0.0" },
  "methods": [
    {
      "name": "send-mail",
      "params": [
        { "name": "to",      "required": true,  "schema": { "type": "string" } },
        { "name": "subject", "required": false, "schema": { "type": "string" } },
        { "name": "body",    "required": false, "schema": { "type": "string" } }
      ],
      "result": { "name": "ok", "schema": { "type": "object" } }
    }
  ]
}
